# ============================================================
#  Anly SaaS Backend — Environment Configuration Example
#  Copy this file to .env and fill in your actual values.
# ============================================================

# ----- Server -----------------------------------------------
PORT=5000
NODE_ENV=development

# ----- MongoDB ----------------------------------------------
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/anly_saas?retryWrites=true&w=majority

# ----- JWT --------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ----- Lemon Squeezy (Payments) ----------------------------
LEMONSQUEEZY_API_KEY=your_api_key_from_lemonsqueezy_here
LEMONSQUEEZY_STORE_ID=your_store_id_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_signing_secret_here

# ----- Frontend (for CORS & redirect URLs) ------------------
CLIENT_URL=http://localhost:5173

# ----- Email (Nodemailer) -----------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Anly Platform <your_email@gmail.com>
